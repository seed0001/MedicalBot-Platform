# Copy to .env and fill in. Never commit .env.

# --- Core ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# --- Database (Railway Postgres plugin provides this) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medbot

# --- Redis (Railway Redis plugin provides this) ---
REDIS_URL=redis://localhost:6379

# --- Secrets ---
# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 32  -- used for at-rest encryption of sensitive columns
ENCRYPTION_KEY=

# --- Google OAuth ---
# console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing by task class. Swap without redeploying.
MODEL_CHAT=anthropic/claude-sonnet-4.5
MODEL_EXTRACT=anthropic/claude-haiku-4.5
MODEL_ANALYZE=anthropic/claude-sonnet-4.5
