# Copy to .env and fill in. Never commit .env.

# --- Core ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# --- Database ---
# Railway's Postgres plugin provides this. Locally, leave it unset to run an
# embedded Postgres (PGlite) with no install: pglite://./.data/medbot
DATABASE_URL=

# --- Demo / exploration ---
# true  -> exposes /auth/demo and the reset controls, seeds mock data on first
#          sign-in, and shows the "Enter demo" button on the home page.
# false -> those routes do not exist at all. Set this once you start using it
#          for real, after running the master reset from Settings.
DEMO_MODE=true

# --- Redis (Railway Redis plugin provides this) ---
REDIS_URL=redis://localhost:6379

# --- Secrets ---
# openssl rand -hex 32
SESSION_SECRET=
# openssl rand -hex 32  -- used for at-rest encryption of sensitive columns
ENCRYPTION_KEY=

# --- Admin ---
# The operator's Google email. On login this account becomes the 'owner', which
# unlocks the admin section and the ability to grant admin to other users.
OWNER_EMAIL=

# --- Google OAuth ---
# console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing by task class. Swap without redeploying.
MODEL_CHAT=anthropic/claude-sonnet-4.5
MODEL_EXTRACT=anthropic/claude-haiku-4.5
MODEL_ANALYZE=anthropic/claude-sonnet-4.5
# Multimodal model for reading uploaded lab reports / prescriptions / scans.
# Must accept images and PDFs.
MODEL_VISION=anthropic/claude-sonnet-4.5
